; Engine configuration file for Voidborne Command
; Godot 4.4.1 - 3D space simulator vertical slice

config_version=5

[application]

config/name="Voidborne Command"
config/description="Original 3D space-sim vertical slice: fly, fight, board, capture, command a fleet."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"
boot_splash/show_image=false

[autoload]

GameConstants="*res://scripts/game_constants.gd"
Game="*res://scripts/game_state.gd"
Capture="*res://scripts/capture.gd"
DebugHud="*res://scripts/debug_hud.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.01, 0.01, 0.03, 1)
anti_aliasing/quality/msaa_3d=1
environment/glow/enabled=true

[audio]

bus/layout="res://default_bus_layout.tres"

[physics]

common/enable_pause_aware_picking=true

