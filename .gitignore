# Godot 4 / engine artifacts
.godot/
.import/
*.import
*.uid
export.cfg
export_presets.cfg
*.translation

# Python
__pycache__/
*.pyc

# Build / capture artifacts
artifacts/screenshots/*.png
artifacts/screenshots/*.jpg
artifacts/baseline/
artifacts/*.log
.studio/*.log

# Secrets / credentials — never commit API keys or env files
.env
.env.*
*.env
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Meshy 3D pipeline scratch (contains signed S3 URLs + task IDs)
.meshy_state.json

# Raw Meshy textures (2048² PNG + 1024² JPEG). The textures are baked into
# the repacked GLBs at 1024² JPEG, so the originals are redundant.
*_Baked_BaseColor.png
*_Baked_BaseColor.jpg
*_normal.png
*_normal.jpg
*_texture_0.png
*_texture_0.jpg

# Raw and intermediate Meshy GLBs. Only the .repacked.glb files are committed.
assets/models/meshy_visual_upgrade/*.glb
!assets/models/meshy_visual_upgrade/*.repacked.glb
